<section class="ui left aligned middle aligned segment">
    <h2>Cat App Dashboard</h2>

    <form action="/searchCategory" method="GET" class="ui form">
        <div class="field">
            <input type="text" name="searchTerm" placeholder="Search by group..." value="{{search}}">
        </div>
        <div class="field">
            <label>Sort by:</label>
            <select class="ui dropdown" name="sort" onchange="this.form.submit()">
                <option value="title" {{#if titleSelected}}selected{{/if}}>groupName</option>
            </select>
        </div>
        
        <div class="field">
            <label>Order</label>
            <select class="ui dropdown" name="order" onchange="this.form.submit()">
                <option value="asc" {{#if ascSelected}}selected{{/if}}↑></option>
                <option value="desc" {{#if descSelected}}selected{{/if}}>↓</option>
            </select>
        </div>
    </form>


    {{#each felines}}
        <section class="ui center aligned middle aligned segment">

            <h3 class="ui left aligned header big">
                {{groupName}}
            </h3>
            {{#if cats}}
            <p class="ui left aligned header">Cats found: {{cats.length}}</p>
            {{else}}
            <p>No cats :C</p>
            {{/if}}

            <a href="felines/{{id}}">
            <i class="massive cat icon "></i></a>
            <a href="/dashboard/deletefeline/{{id}}">
            <i class="ui trash black icon"></i>
            </a>
        
        </section>
    {{/each}}


</section>