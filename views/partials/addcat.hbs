<form class="ui stacked segment form" action="/feline/{{singleFeline.id}}/addCat" method="POST">
  <div class="two fields">
    <div class="field">
      <label>Name</label> 
      <input type="text" name="name" autofocus required title = "Please include a valid Name"
	  placeholder="Name" >
    </div>
    <div class="field">
      <label>Image</label>
      <input type="text" name="image" required title="Include valid path to a image" placeholder="Url">
    </div>
  </div>  
 
  <button class="ui blue submit button">Add Cat</button>
</form>
