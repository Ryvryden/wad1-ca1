{{> menu id="stats"}}

<section class="ui center aligned middle aligned segment">

    <h2>Feline app Statistics</h2>

    <h3 class="ui header">
        App Statistics
    </h3>
    <p>
        The feline app now contains:
    </p>
    {{#with stats}}
    <div class="ui center aligned grid">
        
        <div class="ui sixteen wide column">
            <div class="ui centered two statistics">
                <div class="ui grey statistic">
                    <div class="value">
                        <i class="cat icon"></i>
                    </div>
                    <div class="label">
                        {{displayNumFeline}} felines
                    </div>
                </div>

                <div class="ui grey statistic">
                    <div class="value">
                        <i class="cat icon"></i>
                    </div>
                    <div class="label">
                        {{displayNumCats}} cats
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{/with}}
</section>